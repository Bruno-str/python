class Arqueiro(Personagem):
    __tablename__ = "arqueiros"

    id = Column(Integer, ForeignKey("personagens.id"), primary_key=True)
    alcance = Column(Float, default=30)
    municao = Column(Integer, default=15)
    precisao = Column(Float, default=20)

    __mapper_args__ = {"polymorphic_identity": "arqueiro"}

    def __init__(self, nome, vida=120, nivel=1, mana=60, forca=12, alcance=30, municao=15, precisao=20):
        super().__init__(nome=nome, vida=vida, nivel=nivel, mana=mana, forca=forca)
        self.alcance = alcance
        self.municao = municao
        self.precisao = precisao

    def disparar_flecha(self, alvo):
        if self.municao > 0:
            self.municao -= 1
            print(f"{self.nome} dispara uma flecha em {alvo}! Munição restante: {self.municao}")
        else:
            print(f"{self.nome} está sem flechas!")

    def flecha_explosiva(self, alvo):
        print(f"{self.nome} dispara uma flecha explosiva em {alvo}, causando dano em área!")

