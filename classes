from sqlalchemy import Column, Float, String, Integer, ForeignKey
from .personagem import Personagem

class Guerreiro(Personagem):
    __tablename__ = "guerreiros"

    id = Column(Integer, ForeignKey("personagens.id"), primary_key=True)
    armadura = Column(Float, default=25)
    arma = Column(String, default="Espada Longa")
    vigor = Column(Float, default=15)
    poder = Column(Float, default=50)

    __mapper_args__ = {"polymorphic_identity": "guerreiro"}

    def __init__(self, nome, vida=150, nivel=1, mana=40, forca=20, poder=50, arma="Espada Longa", armadura=25):
        super().__init__(nome=nome, vida=vida, nivel=nivel, mana=mana, forca=forca)
        self.poder = poder
        self.arma = arma
        self.armadura = armadura

    def atacar(self, alvo):
        dano = self.forca + (self.poder * 0.3)
        print(f"{self.nome} ataca {alvo} com {self.arma}, causando {dano:.1f} de dano!")

    def golpe_pesado(self, alvo):
        dano = self.forca + (self.poder * 0.5)
        print(f"{self.nome} realiza um golpe pesado em {alvo}! Dano causado: {dano:.1f}")

    def fortalecer(self):
        self.poder += 10
        print(f"{self.nome} fortalece seus músculos! Poder atual: {self.poder}")



from sqlalchemy import Column, Float, String, Integer, ForeignKey
from .personagem import Personagem

class Mago(Personagem):
    __tablename__ = "magos"

    id = Column(Integer, ForeignKey("personagens.id"), primary_key=True)
    poder_magico = Column(Float, default=40)
    livro_de_magia = Column(String, default="Livro Arcano")
    inteligencia = Column(Float, default=30)

    __mapper_args__ = {"polymorphic_identity": "mago"}

    def __init__(self, nome, vida=100, nivel=1, mana=200, forca=8, poder_magico=40, inteligencia=30, livro_de_magia="Livro Arcano"):
        super().__init__(nome=nome, vida=vida, nivel=nivel, mana=mana, forca=forca)
        self.poder_magico = poder_magico
        self.inteligencia = inteligencia
        self.livro_de_magia = livro_de_magia

    def lancar_feitico(self, feitico, alvo):
        if self.mana >= 10:
            self.mana -= 10
            print(f"{self.nome} lança o feitiço '{feitico}' em {alvo}! (Poder mágico: {self.poder_magico})")
        else:
            print(f"{self.nome} está sem mana suficiente!")

    def recuperar_mana(self):
        self.mana += 15
        print(f"{self.nome} recupera 15 pontos de mana. Mana atual: {self.mana}")

from sqlalchemy import Column, Float, Integer, ForeignKey
